<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:id="@+id/flNativeAd"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/shimmerNativeAd"
            layout="@layout/layout_native_shimmer_full_screen" />

    </FrameLayout>
    <com.dong.baselib.widget.view.UiTextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_4sdp"
        android:text="@string/skip"
        android:fontFamily="@font/rb_400"
        android:includeFontPadding="false"
        android:textSize="@dimen/_12sdp"
        android:visibility="gone"
        tools:visibility="visible"
        android:layout_marginTop="@dimen/_28sdp"
        android:layout_marginEnd="@dimen/_12sdp"
        app:cornerRadius="@dimen/_20sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:stColorAll="@color/white"
        app:tvColor="@color/white"
        app:strokeWidth="@dimen/_1sdp" />
</androidx.constraintlayout.widget.ConstraintLayout>

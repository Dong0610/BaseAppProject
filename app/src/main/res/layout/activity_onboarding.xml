<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundApp"
    tools:context=".ui.onboarding.OnboardingActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <com.dong.baselib.widget.layout.UiLinearLayout
        android:id="@+id/llTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/_8sdp"
        app:bgColorAll="@color/backgroundApp"
        app:bgGdOrientation="bottom_top"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.dong.baselib.widget.layout.UiLinearLayout
            android:id="@+id/llTextContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/_12sdp"
            app:layout_constraintBottom_toBottomOf="@id/flNativeAd">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_12sdp"
                android:layout_marginBottom="@dimen/_8sdp"
                android:fontFamily="@font/rb_500"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:textColor="@color/white"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintBottom_toTopOf="@+id/tvContent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="@tools:sample/lorem/random" />

            <TextView
                android:id="@+id/tvContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_12sdp"
                android:fontFamily="@font/rb_400"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minLines="2"
                android:textColor="@color/color_86909C"
                android:textSize="@dimen/_11sdp"
                app:layout_constraintBottom_toTopOf="@+id/llTabContent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="@tools:sample/lorem/random" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llTabContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="@dimen/_6sdp"
                app:layout_constraintBottom_toTopOf="@id/flNativeAd">

                <com.dong.baselib.widget.view.IndicatorView
                    android:id="@+id/indicatorView"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_7sdp"
                    android:layout_marginStart="@dimen/_18sdp"
                    app:active_color="@color/primary"
                    app:default_color="@color/color_E5E6EB"
                    app:indicator_gradient="true"
                    app:indicator_gradient_end="@color/grdEnd"
                    app:indicator_gradient_start="@color/grdStart"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:max_count="4"
                    app:spacing="@dimen/_7sdp" />

                <com.dong.baselib.widget.view.UiTextView
                    android:id="@+id/tvNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_12sdp"
                    android:fontFamily="@font/rb_500"
                    android:paddingHorizontal="@dimen/_6sdp"
                    android:paddingVertical="@dimen/_3sdp"
                    android:text="@string/next"
                    android:textSize="@dimen/_12sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:textGradient="true"
                    app:textGradientEnd="@color/grdEnd"
                    app:textGradientStart="@color/grdStart"
                    app:tvColor="@color/white" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.dong.baselib.widget.layout.UiLinearLayout>

        <com.dong.baselib.widget.layout.UiFrameLayout
            android:id="@+id/flNativeAd"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <include
                android:id="@+id/shimmerMediaLeft"
                layout="@layout/layout_native_shimmer_media_left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                android:id="@+id/shimmerMediaBottom"
                layout="@layout/layout_native_shimmer_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <include
                android:id="@+id/shimmerNoMedia"
                layout="@layout/layout_native_shimmer_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </com.dong.baselib.widget.layout.UiFrameLayout>
    </com.dong.baselib.widget.layout.UiLinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

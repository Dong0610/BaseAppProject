<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AdFullScreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="HeaderScreenTitle">
        <item name="tvColor">@color/white</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/rb_600</item>
        <item name="android:textSize">@dimen/_14sdp</item>
    </style>

    <style name="ButtonAppStyle">
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">@dimen/_12sdp</item>
        <item name="bgGradientEnd">@color/grdEnd</item>
        <item name="bgGdOrientation">left_right</item>
        <item name="bgGradientStart">@color/grdStart</item>
        <item name="bgIsGradient">true</item>
        <item name="tvColor">@color/white</item>
        <item name="cornerRadius">@dimen/_100sdp</item>
    </style>
</resources>
